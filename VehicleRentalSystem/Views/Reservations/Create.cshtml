@model VehicleRentalSystem.Models.Reservation

<div class="d-flex justify-content-center align-items-center" style="min-height: 80vh;">

    <div class="card shadow p-4" style="width: 400px; background-color: rgba(255,255,255,0.95);">

        <h3 class="text-center mb-3">Create Reservation</h3>

        <form asp-action="Create">

            <div class="mb-3">
                <label class="form-label">Vehicle</label>
                <select asp-for="VehicleId" asp-items="ViewBag.Vehicles" class="form-control"></select>
            </div>

            <div class="mb-3">
                <label class="form-label">Customer</label>
                <select asp-for="CustomerId" asp-items="ViewBag.Customers" class="form-control"></select>
            </div>

            <div class="mb-3">
                <label class="form-label">Start Date</label>
                <input asp-for="StartDate" type="date" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">End Date</label>
                <input asp-for="EndDate" type="date" class="form-control" />
            </div>

            <button type="submit" class="btn btn-primary w-100">Save</button>

        </form>

    </div>

</div>